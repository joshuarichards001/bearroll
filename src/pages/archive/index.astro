---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getAllDayDates } from "../../lib/posts";

const dates = getAllDayDates();
---

<Layout
  title="Archive — Bear Roll"
  description="Browse all collected days of Bear Blog's discover page."
>
  <PageHeader slot="header" title="Archive" />
  <main class="flex flex-col gap-4">
    <a href="/" class="text-muted underline">&larr; back to the roll</a>
    <ul class="flex flex-col gap-2">
      {
        dates.map((date) => (
          <li>
            <a href={`/archive/${date}`} class="text-link hover:underline">
              {date}
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
