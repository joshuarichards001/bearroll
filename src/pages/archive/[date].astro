---
import Layout from "../../layouts/Layout.astro";
import PostItem from "../../components/PostItem.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getAllDayDates, loadDay } from "../../lib/posts";
import { formatDate } from "../../lib/format";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = () => {
  return getAllDayDates().map((date) => ({ params: { date } }));
};

const { date } = Astro.params;
const day = loadDay(date!);
---

<Layout
  title={`${formatDate(date!)} — Bear Roll`}
  description={`Bear Blog discover posts from ${formatDate(date!)}.`}
>
  <PageHeader slot="header" title={formatDate(date!)} />
  <main class="flex flex-col gap-4">
    <a href="/archive" class="text-muted underline">&larr; back to archive</a>
    {
      day ? (
        <ul class="flex flex-col">
          {day.posts.map((post) => (
            <PostItem post={post} />
          ))}
        </ul>
      ) : (
        <p class="text-muted">No posts found for this date.</p>
      )
    }
  </main>
</Layout>
