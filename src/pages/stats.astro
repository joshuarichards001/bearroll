---
import Layout from "../layouts/Layout.astro";
import BlogItem from "../components/BlogItem.astro";
import PostItem from "../components/PostItem.astro";
import PageHeader from "../components/PageHeader.astro";
import { computeStats } from "../lib/stats";

const stats = computeStats();
---

<Layout
  title="Stats — Bear Roll"
  description="Bear Roll stats: most toasted posts, most featured blogs, and totals."
>
  <PageHeader slot="header" title="ʕ●ᴥ●ʔ Bear Roll - Stats" />
  <div class="flex flex-col gap-6">
    <a href="/" class="text-muted underline">&larr; back to the roll</a>
    <div class="flex gap-6 flex-wrap">
      <div class="flex flex-col">
        <span class="text-2xl font-bold text-heading">{stats.totalPosts}</span>
        <span class="text-xs text-muted">posts tracked</span>
      </div>
      <div class="flex flex-col">
        <span class="text-2xl font-bold text-heading">{stats.uniqueBlogs}</span>
        <span class="text-xs text-muted">unique blogs</span>
      </div>
      <div class="flex flex-col">
        <span class="text-2xl font-bold text-heading">{stats.totalDays}</span>
        <span class="text-xs text-muted">days collected</span>
      </div>
    </div>
    <section>
      <h2 class="text-sm font-bold text-heading mb-3">Most Toasted Posts</h2>
      <ol class="flex flex-col">
        {stats.topPosts.map((post) => <PostItem post={post} />)}
      </ol>
    </section>
    <section>
      <h2 class="text-sm font-bold text-heading mb-3">Most Featured Blogs</h2>
      <ol class="flex flex-col">
        {stats.topBlogs.map((blog, i) => <BlogItem blog={blog} rank={i + 1} />)}
      </ol>
    </section>
  </div>
</Layout>
