---
import Layout from "../layouts/Layout.astro";
import { loadAllDays } from "../lib/posts";

const days = loadAllDays();

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + "T12:00:00Z");
  return d.toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<Layout title="bear discover">
  <header>
    <div class="header-inner">
      <div class="title-row">
        <h1><a href="/">bear discover</a></h1>
        <span class="subtitle">posts from Bear Blog's discover page</span>
      </div>
      <nav class="filters">
        <button class="filter-btn active" data-filter="10">top 10</button>
        <button class="filter-btn" data-filter="20">top 20</button>
        <button class="filter-btn" data-filter="all">all</button>
      </nav>
    </div>
  </header>

  <main>
    {days.length === 0 && <p class="empty">No posts collected yet.</p>}
    {days.map((day) => (
      <section class="day-section">
        <h2 class="day-header">
          <span class="day-label">{formatDate(day.date)}</span>
        </h2>
        <ul class="post-list">
          {day.posts.map((post) => (
            <li class="post-item" data-rank={post.rank}>
              <span class="toasts">{post.toasts}</span>
              <a href={post.url} class="post-title" target="_blank" rel="noopener">
                {post.title}
              </a>
              <a
                href={post.author}
                class="post-domain"
                target="_blank"
                rel="noopener"
              >
                ({post.domain})
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLLIElement>(".post-item");

  function applyFilter(filter: string) {
    const max = filter === "all" ? Infinity : parseInt(filter, 10);
    items.forEach((item) => {
      const rank = parseInt(item.dataset.rank!, 10);
      item.classList.toggle("hidden-by-filter", rank > max);
    });
    buttons.forEach((btn) =>
      btn.classList.toggle("active", btn.dataset.filter === filter)
    );
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => applyFilter(btn.dataset.filter!));
  });

  // Default: top 10
  applyFilter("10");
</script>

<style>
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  h1 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
  }

  h1 a {
    color: var(--fg);
    text-decoration: none;
  }

  .subtitle {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .filters {
    display: flex;
    gap: 0;
  }

  .filter-btn {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    padding: 0.25rem 0.6rem;
    font-size: 0.75rem;
    cursor: pointer;
    color: var(--fg);
    font-family: inherit;
    margin-left: -1px;
  }

  .filter-btn:first-child {
    margin-left: 0;
    border-radius: 3px 0 0 3px;
  }

  .filter-btn:last-child {
    border-radius: 0 3px 3px 0;
  }

  .filter-btn.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    z-index: 1;
    position: relative;
  }

  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1rem 2rem;
  }

  .empty {
    padding: 2rem 0;
    color: var(--muted);
    text-align: center;
  }

  .day-section {
    margin-top: 1rem;
  }

  .day-header {
    margin: 0 0 0.25rem;
    font-size: 0.8rem;
    font-weight: 400;
  }

  .day-label {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-weight: 600;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.2rem 0;
    font-size: 0.85rem;
    line-height: 1.4;
    border-bottom: 1px solid var(--border-light);
  }

  .post-item.hidden-by-filter {
    display: none;
  }

  .toasts {
    flex-shrink: 0;
    width: 2.5rem;
    text-align: right;
    color: var(--muted);
    font-size: 0.8rem;
  }

  .post-title {
    color: var(--fg);
    text-decoration: none;
  }

  .post-title:hover {
    text-decoration: underline;
  }

  .post-domain {
    flex-shrink: 0;
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
    white-space: nowrap;
  }

  .post-domain:hover {
    text-decoration: underline;
  }
</style>
