---
import Layout from "../layouts/Layout.astro";
import { loadInitialDays, getRemainingDayDates } from "../lib/posts";

const days = loadInitialDays();
const remainingDates = getRemainingDayDates();

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + "T12:00:00Z");
  return d.toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<Layout title="bear discover">
  <header>
    <div class="header-inner">
      <div class="title-row">
        <h1><a href="/">bear discover</a></h1>
        <span class="subtitle">posts from Bear Blog's discover page</span>
      </div>
      <nav class="filters">
        <button class="filter-btn active" data-filter="10">top 10</button>
        <button class="filter-btn" data-filter="20">top 20</button>
        <button class="filter-btn" data-filter="all">all</button>
      </nav>
    </div>
  </header>

  <main>
    {days.length === 0 && <p class="empty">No posts collected yet.</p>}
    {days.map((day) => (
      <section class="day-section">
        <h2 class="day-header">
          <span class="day-label">{formatDate(day.date)}</span>
        </h2>
        <ul class="post-list">
          {day.posts.map((post) => (
            <li class="post-item" data-rank={post.rank}>
              <span class="toasts">{post.toasts}</span>
              <a href={post.url} class="post-title" target="_blank" rel="noopener">
                {post.title}
              </a>
              <a
                href={post.author}
                class="post-domain"
                target="_blank"
                rel="noopener"
              >
                ({post.domain})
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
    <div id="scroll-sentinel"></div>
    <div id="load-status" class="load-status"></div>
  </main>
</Layout>

<script define:vars={{ remainingDates }}>
  window.__remainingDates = remainingDates;
</script>

<script>
  const main = document.querySelector("main")!;
  const sentinel = document.getElementById("scroll-sentinel")!;
  const status = document.getElementById("load-status")!;
  const dates: string[] = (window as any).__remainingDates;
  let currentFilter = "10";
  let loading = false;
  let nextIndex = 0;

  function formatDate(dateStr: string): string {
    const d = new Date(dateStr + "T12:00:00Z");
    return d.toLocaleDateString("en-US", {
      weekday: "short",
      month: "short",
      day: "numeric",
      timeZone: "UTC",
    });
  }

  function applyFilterToItems(items: NodeListOf<HTMLLIElement> | HTMLLIElement[]) {
    const max = currentFilter === "all" ? Infinity : parseInt(currentFilter, 10);
    items.forEach((item) => {
      const rank = parseInt(item.dataset.rank!, 10);
      item.classList.toggle("hidden-by-filter", rank > max);
    });
  }

  function applyFilter(filter: string) {
    currentFilter = filter;
    const items = document.querySelectorAll<HTMLLIElement>(".post-item");
    applyFilterToItems(items);
    document.querySelectorAll<HTMLButtonElement>(".filter-btn").forEach((btn) =>
      btn.classList.toggle("active", btn.dataset.filter === filter)
    );
  }

  document.querySelectorAll<HTMLButtonElement>(".filter-btn").forEach((btn) => {
    btn.addEventListener("click", () => applyFilter(btn.dataset.filter!));
  });

  applyFilter("10");

  interface PostData {
    url: string;
    title: string;
    author: string;
    toasts: number;
    rank: number;
    domain: string;
  }

  function renderDay(date: string, posts: PostData[]): HTMLElement {
    const section = document.createElement("section");
    section.className = "day-section";

    const h2 = document.createElement("h2");
    h2.className = "day-header";
    const label = document.createElement("span");
    label.className = "day-label";
    label.textContent = formatDate(date);
    h2.appendChild(label);
    section.appendChild(h2);

    const ul = document.createElement("ul");
    ul.className = "post-list";

    const newItems: HTMLLIElement[] = [];
    for (const post of posts) {
      const li = document.createElement("li");
      li.className = "post-item";
      li.dataset.rank = String(post.rank);

      const toasts = document.createElement("span");
      toasts.className = "toasts";
      toasts.textContent = String(post.toasts);
      li.appendChild(toasts);

      const titleLink = document.createElement("a");
      titleLink.className = "post-title";
      titleLink.href = post.url;
      titleLink.target = "_blank";
      titleLink.rel = "noopener";
      titleLink.textContent = post.title;
      li.appendChild(titleLink);

      const domainLink = document.createElement("a");
      domainLink.className = "post-domain";
      domainLink.href = post.author;
      domainLink.target = "_blank";
      domainLink.rel = "noopener";
      domainLink.textContent = `(${post.domain})`;
      li.appendChild(domainLink);

      ul.appendChild(li);
      newItems.push(li);
    }

    section.appendChild(ul);
    applyFilterToItems(newItems);
    return section;
  }

  async function loadNextDay() {
    if (loading || nextIndex >= dates.length) return;
    loading = true;
    status.textContent = "Loading…";

    const date = dates[nextIndex];
    try {
      const res = await fetch(`${import.meta.env.BASE_URL}/api/${date}.json`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const posts: PostData[] = await res.json();
      if (posts.length > 0) {
        const section = renderDay(date, posts);
        sentinel.before(section);
      }
      nextIndex++;
    } catch {
      status.textContent = "Failed to load. Scroll to retry.";
      loading = false;
      return;
    }

    if (nextIndex >= dates.length) {
      status.textContent = "";
      observer.disconnect();
    } else {
      status.textContent = "";
    }
    loading = false;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) loadNextDay();
    },
    { rootMargin: "200px" }
  );

  if (dates.length > 0) {
    observer.observe(sentinel);
  }
</script>

<style>
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  h1 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
  }

  h1 a {
    color: var(--fg);
    text-decoration: none;
  }

  .subtitle {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .filters {
    display: flex;
    gap: 0;
  }

  .filter-btn {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    padding: 0.25rem 0.6rem;
    font-size: 0.75rem;
    cursor: pointer;
    color: var(--fg);
    font-family: inherit;
    margin-left: -1px;
  }

  .filter-btn:first-child {
    margin-left: 0;
    border-radius: 3px 0 0 3px;
  }

  .filter-btn:last-child {
    border-radius: 0 3px 3px 0;
  }

  .filter-btn.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    z-index: 1;
    position: relative;
  }

  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1rem 2rem;
  }

  .empty {
    padding: 2rem 0;
    color: var(--muted);
    text-align: center;
  }

</style>
