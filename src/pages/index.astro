---
import Layout from "../layouts/Layout.astro";
import DaySection from "../components/DaySection.astro";
import Header from "../components/Header.astro";
import { loadInitialDays, getRemainingDayDates } from "../lib/posts";

const days = loadInitialDays();
const remainingDates = getRemainingDayDates();
---

<Layout title="Bear Roll">
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Bear Roll",
      url: "https://bearroll.dev",
      description: "A daily view of the Bear Blog discover page top posts",
    })}
  />
  <Header slot="header" />
  <main class="pb-8 flex flex-col gap-4">
    {days.map((day) => <DaySection day={day} />)}

    <div
      id="scroll-sentinel"
      data-remaining-dates={JSON.stringify(remainingDates)}
    >
    </div>
    <output id="load-status" class="block text-center py-4 text-xs text-muted"
    ></output>
  </main>
</Layout>

<script>
  const sentinel = document.getElementById("scroll-sentinel")!;
  const status = document.getElementById("load-status")!;
  const dates: string[] = JSON.parse(sentinel.dataset.remainingDates ?? "[]");

  const currentFilter = localStorage.getItem("filter") ?? "10";
  let loading = false;
  let nextIndex = 0;

  function applyFilter() {
    const max =
      currentFilter === "all" ? Infinity : parseInt(currentFilter, 10);
    document.querySelectorAll<HTMLLIElement>(".post-item").forEach((item) => {
      item.classList.toggle("hidden", parseInt(item.dataset.rank!, 10) > max);
    });
    document
      .querySelectorAll<HTMLButtonElement>(".filter-btn")
      .forEach((btn) => {
        btn.toggleAttribute(
          "data-active",
          btn.dataset.filter === currentFilter,
        );
      });
  }

  document.querySelectorAll<HTMLButtonElement>(".filter-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;
      if (filter === "10") localStorage.removeItem("filter");
      else localStorage.setItem("filter", filter);
      location.reload();
    });
  });

  applyFilter();

  async function loadNextDay() {
    if (loading || nextIndex >= dates.length) return;
    loading = true;
    status.textContent = "Loading\u2026";

    const date = dates[nextIndex];
    try {
      const res = await fetch(`api/${date}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const html = await res.text();
      sentinel.insertAdjacentHTML("beforebegin", html);
      applyFilter();
      nextIndex++;
    } catch {
      status.textContent = "Failed to load. Scroll to retry.";
      loading = false;
      return;
    }

    status.textContent = "";
    loading = false;
  }

  window.addEventListener(
    "scroll",
    () => {
      if (
        window.innerHeight + window.scrollY >=
        document.body.scrollHeight - 200
      ) {
        loadNextDay();
      }
    },
    { passive: true },
  );
</script>
