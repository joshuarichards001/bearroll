---
import Layout from "../layouts/Layout.astro";
import { loadInitialDays, getRemainingDayDates } from "../lib/posts";

const days = loadInitialDays();
const remainingDates = getRemainingDayDates();

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + "T12:00:00Z");
  return d.toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<Layout title="bear discover">
  <header class="border-b border-border bg-bg sticky top-0 z-10">
    <div class="max-w-[720px] mx-auto px-4 py-3 flex items-center justify-between gap-4 flex-wrap">
      <div class="flex items-baseline gap-3">
        <h1 class="text-lg font-bold">
          <a href="/" class="text-fg no-underline">bear discover</a>
        </h1>
        <span class="text-xs text-muted">posts from Bear Blog's discover page</span>
      </div>
      <nav class="flex">
        <button class="filter-btn bg-bg-alt border border-border px-2.5 py-1 text-xs cursor-pointer text-fg -ml-px first:ml-0 first:rounded-l-sm last:rounded-r-sm" data-filter="10">top 10</button>
        <button class="filter-btn bg-bg-alt border border-border px-2.5 py-1 text-xs cursor-pointer text-fg -ml-px first:ml-0 first:rounded-l-sm last:rounded-r-sm" data-filter="20">top 20</button>
        <button class="filter-btn bg-bg-alt border border-border px-2.5 py-1 text-xs cursor-pointer text-fg -ml-px first:ml-0 first:rounded-l-sm last:rounded-r-sm" data-filter="all">all</button>
      </nav>
    </div>
  </header>

  <main class="max-w-[720px] mx-auto px-4 pb-8">
    {days.length === 0 && <p class="py-8 text-muted text-center">No posts collected yet.</p>}
    {days.map((day) => (
      <section class="mt-4">
        <h2 class="mb-1 text-xs font-normal">
          <span class="inline-block bg-accent text-white px-2 py-0.5 rounded-sm font-semibold">{formatDate(day.date)}</span>
        </h2>
        <ul>
          {day.posts.map((post) => (
            <li class="post-item flex items-baseline gap-2 py-0.5 text-sm leading-snug border-b border-border-light" data-rank={post.rank}>
              <span class="shrink-0 w-10 text-right text-muted text-xs">{post.toasts}</span>
              <a href={post.url} class="min-w-0 truncate text-fg no-underline hover:underline" target="_blank" rel="noopener">
                {post.title}
              </a>
              <a
                href={post.author}
                class="shrink-0 text-xs text-muted no-underline whitespace-nowrap hover:underline"
                target="_blank"
                rel="noopener"
              >
                ({post.domain})
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
    <div id="scroll-sentinel"></div>
    <div id="load-status" class="text-center py-4 text-xs text-muted"></div>
  </main>
</Layout>

<script define:vars={{ remainingDates }}>
  window.__remainingDates = remainingDates;
</script>

<script>
  const main = document.querySelector("main")!;
  const sentinel = document.getElementById("scroll-sentinel")!;
  const status = document.getElementById("load-status")!;
  const dates: string[] = (window as any).__remainingDates;
  let currentFilter = "10";
  let loading = false;
  let nextIndex = 0;

  function formatDate(dateStr: string): string {
    const d = new Date(dateStr + "T12:00:00Z");
    return d.toLocaleDateString("en-US", {
      weekday: "short",
      month: "short",
      day: "numeric",
      timeZone: "UTC",
    });
  }

  function applyFilterToItems(items: NodeListOf<HTMLLIElement> | HTMLLIElement[]) {
    const max = currentFilter === "all" ? Infinity : parseInt(currentFilter, 10);
    items.forEach((item) => {
      const rank = parseInt(item.dataset.rank!, 10);
      item.classList.toggle("hidden", rank > max);
    });
  }

  function applyFilter(filter: string) {
    currentFilter = filter;
    const items = document.querySelectorAll<HTMLLIElement>(".post-item");
    applyFilterToItems(items);
    document.querySelectorAll<HTMLButtonElement>(".filter-btn").forEach((btn) => {
      const isActive = btn.dataset.filter === filter;
      btn.classList.toggle("!bg-accent", isActive);
      btn.classList.toggle("!text-white", isActive);
      btn.classList.toggle("!border-accent", isActive);
      btn.classList.toggle("relative", isActive);
      btn.classList.toggle("z-[1]", isActive);
    });
  }

  document.querySelectorAll<HTMLButtonElement>(".filter-btn").forEach((btn) => {
    btn.addEventListener("click", () => applyFilter(btn.dataset.filter!));
  });

  applyFilter("10");

  interface PostData {
    url: string;
    title: string;
    author: string;
    toasts: number;
    rank: number;
    domain: string;
  }

  function renderDay(date: string, posts: PostData[]): HTMLElement {
    const section = document.createElement("section");
    section.className = "mt-4";

    const h2 = document.createElement("h2");
    h2.className = "mb-1 text-xs font-normal";
    const label = document.createElement("span");
    label.className = "inline-block bg-accent text-white px-2 py-0.5 rounded-sm font-semibold";
    label.textContent = formatDate(date);
    h2.appendChild(label);
    section.appendChild(h2);

    const ul = document.createElement("ul");
    ul.className = "";

    const newItems: HTMLLIElement[] = [];
    for (const post of posts) {
      const li = document.createElement("li");
      li.className = "post-item flex items-baseline gap-2 py-0.5 text-sm leading-snug border-b border-border-light";
      li.dataset.rank = String(post.rank);

      const toasts = document.createElement("span");
      toasts.className = "shrink-0 w-10 text-right text-muted text-xs";
      toasts.textContent = String(post.toasts);
      li.appendChild(toasts);

      const titleLink = document.createElement("a");
      titleLink.className = "min-w-0 truncate text-fg no-underline hover:underline";
      titleLink.href = post.url;
      titleLink.target = "_blank";
      titleLink.rel = "noopener";
      titleLink.textContent = post.title;
      li.appendChild(titleLink);

      const domainLink = document.createElement("a");
      domainLink.className = "shrink-0 text-xs text-muted no-underline whitespace-nowrap hover:underline";
      domainLink.href = post.author;
      domainLink.target = "_blank";
      domainLink.rel = "noopener";
      domainLink.textContent = `(${post.domain})`;
      li.appendChild(domainLink);

      ul.appendChild(li);
      newItems.push(li);
    }

    section.appendChild(ul);
    applyFilterToItems(newItems);
    return section;
  }

  async function loadNextDay() {
    if (loading || nextIndex >= dates.length) return;
    loading = true;
    status.textContent = "Loading\u2026";

    const date = dates[nextIndex];
    try {
      const res = await fetch(`${import.meta.env.BASE_URL}/api/${date}.json`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const posts: PostData[] = await res.json();
      if (posts.length > 0) {
        const section = renderDay(date, posts);
        sentinel.before(section);
      }
      nextIndex++;
    } catch {
      status.textContent = "Failed to load. Scroll to retry.";
      loading = false;
      return;
    }

    if (nextIndex >= dates.length) {
      status.textContent = "";
      observer.disconnect();
    } else {
      status.textContent = "";
    }
    loading = false;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) loadNextDay();
    },
    { rootMargin: "200px" }
  );

  if (dates.length > 0) {
    observer.observe(sentinel);
  }
</script>
