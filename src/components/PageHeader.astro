---
import BearMenu from "./BearMenu.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="border-b border-border bg-bg">
  <div class="max-w-3xl mx-auto px-4 py-4">
    <h1 class="text-xl font-bold text-heading mb-4">
      <a href="/">ʕ●ᴥ●ʔ Bear Roll</a> - {title}
    </h1>
    <BearMenu />
  </div>
</header>
