---
const filters = [
  { value: "10", label: "top 10" },
  { value: "20", label: "top 20" },
  { value: "all", label: "all" },
];
---

<header class="border-b border-border bg-bg">
  <div class="mx-auto p-4 flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-xl font-bold">
        <span id="bear-title" class="text-heading cursor-pointer select-none">ʕ-ᴥ-ʔ Bear Roll</span>
      </h1>
      <a id="about-link" href="/about" class="text-xs text-muted underline hidden">about this site</a>
    </div>
    <nav class="flex">
      {filters.map((f) => (
        <button
          class="filter-btn bg-bg-alt border border-border px-2.5 py-1 text-xs cursor-pointer text-fg -ml-px first:ml-0 first:rounded-l-sm last:rounded-r-sm data-[active]:bg-accent data-[active]:text-white data-[active]:border-accent data-[active]:relative data-[active]:z-[1]"
          data-filter={f.value}
        >
          {f.label}
        </button>
      ))}
    </nav>
  </div>
  <div class="mx-auto px-4 pb-2">
    <span class="text-xs text-muted">A chronological roll of <a href="https://bearblog.dev/discover/" class="text-muted underline">bear blog's discover page</a>.</span>
  </div>
</header>

<script>
  const title = document.getElementById("bear-title")!;
  const aboutLink = document.getElementById("about-link")!;
  const sleeping = "ʕ-ᴥ-ʔ Bear Roll";
  const awake = "ʕ●ᴥ●ʔ Bear Roll";
  let isAwake = false;

  title.addEventListener("click", () => {
    isAwake = !isAwake;
    title.textContent = isAwake ? awake : sleeping;
    aboutLink.classList.toggle("hidden", !isAwake);
  });
</script>
