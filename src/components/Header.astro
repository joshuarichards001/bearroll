---
import { getLastCollectedAt } from "../lib/posts";

const lastCollectedAt = getLastCollectedAt();

const filters = [
  { value: "10", label: "top 10" },
  { value: "20", label: "top 20" },
  { value: "all", label: "all" },
];
---

<header class="border-b border-border bg-bg">
  <div class="mx-auto p-4 flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-xl font-bold">
        <span id="bear-title" class="text-heading cursor-pointer select-none"
          >ʕ-ᴥ-ʔ Bear Roll</span
        >
      </h1>
      <a
        id="about-link"
        href="/about"
        class="text-xs text-muted underline hidden">about this site</a
      >
    </div>
    <nav class="flex">
      {
        filters.map((f) => (
          <button
            class="filter-btn bg-bg-alt border border-border px-2.5 py-1 text-xs cursor-pointer text-fg -ml-px first:ml-0 first:rounded-l-sm last:rounded-r-sm data-[active]:bg-accent data-[active]:text-white data-[active]:border-accent data-[active]:relative data-[active]:z-[1]"
            data-filter={f.value}
          >
            {f.label}
          </button>
        ))
      }
    </nav>
  </div>
  <div class="flex justify-between px-4 pb-2 gap-2">
    <span class="text-xs text-muted"
      >A chronological roll of Bear Blog's <a
        href="https://bearblog.dev/discover/"
        class="text-muted underline">discover page</a
      >.</span
    >
    {
      lastCollectedAt && (
        <span
          id="last-updated"
          class="text-xs text-muted text-right hidden"
          data-collected-at={lastCollectedAt}
        >
          Posts updated daily. Last updated{" "}
          <span id="last-updated-ago" class="text-fg" />.
        </span>
      )
    }
  </div>
</header>

<script>
  const title = document.getElementById("bear-title")!;
  const aboutLink = document.getElementById("about-link")!;
  const sleeping = "ʕ-ᴥ-ʔ Bear Roll";
  const awake = "ʕ●ᴥ●ʔ Bear Roll";
  let isAwake = false;

  title.addEventListener("click", () => {
    isAwake = !isAwake;
    title.textContent = isAwake ? awake : sleeping;
    aboutLink.classList.toggle("hidden", !isAwake);
  });

  const lastUpdatedEl = document.getElementById("last-updated");
  const agoEl = document.getElementById("last-updated-ago");

  if (lastUpdatedEl && agoEl) {
    const collectedAt = lastUpdatedEl.dataset.collectedAt;
    if (collectedAt) {
      function formatAgo(ms: number): string {
        const mins = Math.floor(ms / 60000);
        if (mins < 1) return "just now";
        if (mins < 60) return `${mins}m ago`;
        const hrs = Math.floor(mins / 60);
        if (hrs < 24) return `${hrs}h ago`;
        const days = Math.floor(hrs / 24);
        return `${days}d ago`;
      }

      const elapsed = Date.now() - new Date(collectedAt).getTime();
      agoEl.textContent = formatAgo(elapsed);
      lastUpdatedEl.classList.remove("hidden");
    }
  }
</script>
