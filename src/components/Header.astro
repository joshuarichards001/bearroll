---
import BearMenu from "./BearMenu.astro";
import { getLastCollectedAt } from "../lib/posts";

const lastCollectedAt = getLastCollectedAt();

const filters = [
  { value: "10", label: "top 10" },
  { value: "all", label: "all" },
];
---

<header class="border-b border-border bg-bg">
  <div class="max-w-4xl mx-auto px-4 py-4 flex flex-col gap-4">
    <div class="flex justify-between gap-2 flex-wrap">
      <h1 class="text-xl font-bold text-heading">
        <span id="bear-title" class="cursor-pointer">ʕ-ᴥ-ʔ Bear Roll</span>
      </h1>
      <nav class="flex">
        {
          filters.map((f) => (
            <button
              class="filter-btn bg-bg-alt border border-border px-2.5 py-1 text-xs cursor-pointer text-fg first:rounded-l-sm last:rounded-r-sm data-active:bg-accent data-active:text-white data-active:border-accent"
              data-filter={f.value}
            >
              {f.label}
            </button>
          ))
        }
      </nav>
    </div>
    <div id="bear-menu" class="hidden">
      <BearMenu />
    </div>
    <div class="flex justify-between gap-2">
      <span class="text-xs text-muted"
        >A chronological roll of Bear Blog's <a
          href="https://bearblog.dev/discover/"
          class="text-muted underline">discover page</a
        >.</span
      >
      <span class="text-xs text-muted text-right">
        Posts updated daily. Last updated
        <time
          id="last-updated-ago"
          class="text-fg"
          datetime={lastCollectedAt}
          data-collected-at={lastCollectedAt}>?h ago</time
        >
      </span>
    </div>
  </div>
</header>

<script>
  const title = document.getElementById("bear-title")!;
  const bearMenu = document.getElementById("bear-menu")!;
  const sleeping = "ʕ-ᴥ-ʔ Bear Roll";
  const awake = "ʕ●ᴥ●ʔ Bear Roll";
  let isAwake = false;

  title.addEventListener("click", () => {
    isAwake = !isAwake;
    title.textContent = isAwake ? awake : sleeping;
    bearMenu.classList.toggle("hidden", !isAwake);
    bearMenu.classList.toggle("flex", isAwake);
  });

  const agoEl = document.getElementById("last-updated-ago");

  if (agoEl) {
    const collectedAt = agoEl.dataset.collectedAt;
    if (collectedAt) {
      function formatAgo(ms: number): string {
        const mins = Math.floor(ms / 60000);
        if (mins < 1) return "just now";
        if (mins < 60) return `${mins}m ago`;
        const hrs = Math.floor(mins / 60);
        if (hrs < 24) return `${hrs}h ago`;
        const days = Math.floor(hrs / 24);
        return `${days}d ago`;
      }

      const elapsed = Date.now() - new Date(collectedAt).getTime();
      agoEl.textContent = formatAgo(elapsed);
    }
  }
</script>
