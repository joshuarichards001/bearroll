---
import { medalClass } from "../lib/format";
import type { RankedPost } from "../lib/posts";

interface Props {
  post: RankedPost;
}

const { post } = Astro.props;
---

<li
  class="post-item flex items-baseline py-1.5 leading-snug"
  data-rank={post.rank}
>
  <span class:list={["shrink-0 w-10 text-right mr-4", medalClass(post.rank)]}>
    {post.toasts}
  </span>
  <span>
    <a href={post.url} class="text-link visited:text-visited hover:underline">
      {post.title}
    </a>
    <span class="text-xs text-muted">
      ({post.domain})
    </span>
  </span>
</li>
