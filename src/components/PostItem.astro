---
import { medalClass } from "../lib/format";
import type { RankedPost } from "../lib/posts";

interface Props {
  post: RankedPost;
}

const { post } = Astro.props;
---

<li
  class:list={["post-item leading-snug", { hidden: post.rank > 10 }]}
  data-rank={post.rank}
>
  <a
    href={post.url}
    class="post-link group flex items-baseline py-1.5 w-full no-underline [&:visited_.title]:text-visited active:bg-active hover:bg-hover focus:bg-active rounded-lg"
  >
    <span
      class:list={[
        "shrink-0 w-10 flex items-center justify-end gap-0.5 mr-4",
        medalClass(post.rank),
      ]}
    >
      <svg
        viewBox="0 0 24 24"
        class="h-4 w-4 shrink-0 -mr-0.5"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><polyline points="17 11 12 6 7 11"></polyline><polyline
          points="17 18 12 13 7 18"></polyline></svg
      >
      {post.toasts}
    </span>
    <span>
      <span class="title text-link group-hover:underline">{post.title}</span>
      <span class="text-xs text-muted">
        ({post.domain})
      </span>
    </span>
  </a>
</li>

<style>
  .post-link {
    -webkit-tap-highlight-color: rgba(0, 0, 0, 0.04);
  }

  @media (prefers-color-scheme: dark) {
    .post-link {
      -webkit-tap-highlight-color: rgba(255, 255, 255, 0.04);
    }
  }
</style>
