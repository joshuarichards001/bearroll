---
import { medalClass } from "../lib/format";
import type { RankedPost } from "../lib/posts";

interface Props {
  post: RankedPost;
}

const { post } = Astro.props;
---

<li class="post-item leading-snug" data-rank={post.rank}>
  <a
    href={post.url}
    class="post-link group flex items-baseline py-1.5 w-full no-underline [&:visited_.title]:text-visited active:bg-active rounded-lg"
  >
    <span class:list={["shrink-0 w-10 text-right mr-4", medalClass(post.rank)]}>
      {post.toasts}
    </span>
    <span>
      <span class="title text-link group-hover:underline">{post.title}</span>
      <span class="text-xs text-muted">
        ({post.domain})
      </span>
    </span>
  </a>
</li>

<style>
  .post-link {
    -webkit-tap-highlight-color: rgba(0, 0, 0, 0.04);
  }

  @media (prefers-color-scheme: dark) {
    .post-link {
      -webkit-tap-highlight-color: rgba(255, 255, 255, 0.04);
    }
  }
</style>
