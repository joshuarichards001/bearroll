---
import PostItem from "./PostItem.astro";
import { formatDate } from "../lib/format";
import type { DayGroup } from "../lib/posts";

interface Props {
  day: DayGroup;
}

const { day } = Astro.props;
---

<section>
  <h2 class="mb-2 text-xs font-normal">
    <time
      datetime={day.date}
      class="inline-block bg-accent text-white px-2 py-0.5 rounded-sm font-semibold"
    >
      {formatDate(day.date)}
    </time>
  </h2>
  <ul>
    {day.posts.map((post) => <PostItem post={post} />)}
  </ul>
</section>
