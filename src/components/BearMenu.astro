---
const links = [
  { href: "/about", label: "about" },
  { href: "/archive", label: "archive" },
  { href: "/stats", label: "stats" },
  { href: "/rss.xml", label: "daily rss" },
];
---

<div id="bear-menu" class="hidden gap-4 mt-4">
  {
    links.map((link) => (
      <a href={link.href} class="text-xs text-muted underline">
        {link.label}
      </a>
    ))
  }
</div>
