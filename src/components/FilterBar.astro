---
const filters = [
  { value: "10", label: "top 10" },
  { value: "20", label: "top 20" },
  { value: "all", label: "all" },
];
---

<nav class="flex">
  {filters.map((f) => (
    <button
      class="filter-btn bg-bg-alt border border-border px-2.5 py-1 text-xs cursor-pointer text-fg -ml-px first:ml-0 first:rounded-l-sm last:rounded-r-sm data-[active]:bg-accent data-[active]:text-white data-[active]:border-accent data-[active]:relative data-[active]:z-[1]"
      data-filter={f.value}
    >
      {f.label}
    </button>
  ))}
</nav>
